{
	"extends": "https://raw.githubusercontent.com/kjanat/kjanat/master/configs/dprint.remote.json",
	"markdown": { "associations": ["!README.md"] },
	"prettier": { "associations": ["README.md"], "useTabs": false, "printWidth": 80 },
	"exec": {
		"associations": ["package.json"],
		"commands": [{ "command": "bunx sort-package-json --stdin", "fileNames": ["package.json"] }],
	},
	"plugins": [
		"https://plugins.dprint.dev/exec-0.6.2.json@df98f54ffd3092b8a841aedd6d098a2651f16d0a796a40535774f1a8b4b9d463",
		"https://plugins.dprint.dev/prettier-0.69.0.json@3de5c7cf5cdbae7b214f404b12503c92e7964be5fffd442b998e6d5fe4ba0e7b",
	],
}
