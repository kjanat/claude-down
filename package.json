{
	"name": "claude-down",
	"version": "0.1.3",
	"description": "Is claude code down?",
	"homepage": "https://github.com/kjanat/claude-down#readme",
	"bugs": {
		"url": "https://github.com/kjanat/claude-down/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kjanat/claude-down.git"
	},
	"license": "MIT",
	"author": "Kaj Kowalski",
	"type": "module",
	"imports": {
		"#claude-down": "./src/index.ts",
		"#claude-down/print": "./src/print/index.ts",
		"#claude-down/sources": "./src/sources/index.ts",
		"#claude-down/*": "./src/*"
	},
	"exports": {
		".": "./dist/index.js",
		"./browser": "./dist/browser.js"
	},
	"module": "dist/index.mjs",
	"bin": "dist/main.mjs",
	"scripts": {
		"build": "tsdown",
		"fmt": "bunx dprint fmt",
		"prepublishOnly": "bun run build",
		"test": "bun test",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@kjanat/dreamcli": ">=2.0.1, <2.1.0"
	},
	"devDependencies": {
		"@types/node": "^25.6.0",
		"tsdown": "^0.21.8",
		"typescript": "^6.0.2"
	},
	"packageManager": "bun@1.3.12",
	"engines": {
		"bun": ">=1.3",
		"node": ">=24"
	}
}
