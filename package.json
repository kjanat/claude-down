{
	"name": "claude-down",
	"version": "0.2.0",
	"description": "Is claude code down?",
	"homepage": "https://github.com/kjanat/claude-down#readme",
	"bugs": {
		"url": "https://github.com/kjanat/claude-down/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kjanat/claude-down.git"
	},
	"license": "MIT",
	"author": "Kaj Kowalski",
	"type": "module",
	"imports": {
		"#claude-down": "./src/index.ts",
		"#claude-down/*": "./src/*"
	},
	"exports": {
		".": "./dist/index.mjs",
		"./browser": "./dist/browser/browser.js",
		"./cli": "./dist/bin/cli.mjs",
		"./package.json": "./package.json"
	},
	"bin": {
		"claude-down": "./dist/bin/cli.mjs"
	},
	"scripts": {
		"build": "tsdown",
		"check": "biome check",
		"fmt": "bunx dprint fmt",
		"lint": "biome lint",
		"prepublishOnly": "bun run build",
		"test": "bun test",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@kjanat/dreamcli": ">=2.0.1, <2.1.0",
		"statuspage.io": "*"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.11",
		"@types/node": "^25.6.0",
		"tsdown": "^0.21.8",
		"typescript": "^6.0.2"
	},
	"packageManager": "bun@1.3.12",
	"engines": {
		"bun": ">=1.3",
		"node": ">=24"
	},
	"devEngines": {
		"packageManager": [
			{
				"name": "bun",
				"onFail": "error"
			}
		],
		"runtime": [
			{
				"name": "bun",
				"onFail": "error"
			}
		]
	},
	"inlinedDependencies": {
		"@ffflorian/api-client": "2.5.1",
		"statuspage.io": "3.4.7"
	}
}
