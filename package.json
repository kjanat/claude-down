{
	"name": "claude-down",
	"version": "0.0.3",
	"description": "Is claude code down?",
	"homepage": "https://github.com/kjanat/claude-down#readme",
	"bugs": {
		"url": "https://github.com/kjanat/claude-down/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kjanat/claude-down.git"
	},
	"license": "MIT",
	"author": "Kaj Kowalski",
	"type": "module",
	"module": "src/index.ts",
	"bin": "dist/main.mjs",
	"scripts": {
		"build": "rm -rf ./dist; bun build src/main.ts --target=node --outfile=dist/main.mjs --format=esm --production",
		"fmt": "bunx dprint fmt",
		"prepare": "bun run build",
		"test": "bun test",
		"typecheck": "tsc --noEmit"
	},
	"devDependencies": {
		"@types/node": "^24",
		"typescript": "^6.0.2"
	},
	"packageManager": "bun@1.3.12",
	"engines": {
		"bun": ">=1.3",
		"node": ">=24"
	}
}
