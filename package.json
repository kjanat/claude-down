{
	"name": "claude-down",
	"version": "0.1.3",
	"description": "Is claude code down?",
	"homepage": "https://github.com/kjanat/claude-down#readme",
	"bugs": {
		"url": "https://github.com/kjanat/claude-down/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kjanat/claude-down.git"
	},
	"license": "MIT",
	"author": "Kaj Kowalski",
	"type": "module",
	"imports": {
		"#claude-down": "./src/index.ts",
		"#claude-down/print": "./src/print/index.ts",
		"#claude-down/sources": "./src/sources/index.ts",
		"#claude-down/*": "./src/*"
	},
	"module": "src/index.ts",
	"bin": "dist/main.mjs",
	"scripts": {
		"build": "rm -rf ./dist; bun build src/main.ts --target=node --outfile=dist/main.mjs --external=@kjanat/dreamcli --format=esm --production --banner='#!/usr/bin/env node'",
		"bundle": "rm -rf ./dist; bun build src/main.ts --target=node --outfile=dist/main.mjs --format=esm --production --banner='#!/usr/bin/env node'",
		"fmt": "bunx dprint fmt",
		"prepare": "bun bundle",
		"prepublishOnly": "bun run build",
		"test": "bun test",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@kjanat/dreamcli": ">=2.0.1, <2.1.0"
	},
	"devDependencies": {
		"@types/node": "^24",
		"typescript": "^6.0.2"
	},
	"packageManager": "bun@1.3.12",
	"engines": {
		"bun": ">=1.3",
		"node": ">=24"
	}
}
